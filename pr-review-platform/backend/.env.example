# Runtime connection (Supabase transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Shared secret — must match BACKEND_API_KEY on Vercel
API_KEY="generate-a-long-random-string"

# GitHub PAT — needs read access to the repo + write access to PR comments (issues: write)
GITHUB_TOKEN="ghp_xxxxxxxx"

# Claude API — used for manual reviews from the dashboard
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"

# Azure DevOps — optional, for bug fix verification from PR titles
AZURE_DEVOPS_ORG="your-org"
AZURE_DEVOPS_PAT="your-pat-with-work-items-read"

PORT=3001
